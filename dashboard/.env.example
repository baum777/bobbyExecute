################################################################################
# Dashboard Frontend Environment Configuration
# Copy to .env.local and fill in values for your environment
################################################################################

# NEXT_PUBLIC_API_URL: Bot API Server URL
# - Local development: http://127.0.0.1:3333
# - Production on Vercel: https://your-bot-api.com:3333 (or Render/Railway URL)
# - Tunnel (ngrok/localtunnel): https://xxx.ngrok.io:3333
# NOTE: Must be publicly accessible. Bot API requires CORS configuration.
NEXT_PUBLIC_API_URL=http://127.0.0.1:3333

# NEXT_PUBLIC_USE_MOCK: Use mock data (no backend required)
# - true: Offline mock data (development/testing without backend)
# - false: Real API calls to NEXT_PUBLIC_API_URL
NEXT_PUBLIC_USE_MOCK=false

################################################################################
# DASHBOARD SERVER CONTROL PROXY (dashboard service only)
################################################################################

# CONTROL_SERVICE_URL: Explicit control-service base URL used by the dashboard proxy.
# For local boot, point this at the control service started on 127.0.0.1:3334.
CONTROL_SERVICE_URL=http://127.0.0.1:3334

# CONTROL_SERVICE_HOSTNAME / CONTROL_SERVICE_PORT: fallback wiring if CONTROL_SERVICE_URL is not set.
CONTROL_SERVICE_HOSTNAME=127.0.0.1
CONTROL_SERVICE_PORT=3334

# CONTROL_TOKEN: Shared bearer token for control proxying.
# - Safe boot / paper: required for local read access if the dashboard talks to control
# - Local live-limited: required and secret
# - Used for real control-path reads and writes
CONTROL_TOKEN=

# OPERATOR_READ_TOKEN: Read-only token for GET/HEAD control requests.
# - Safe boot / paper: use a distinct local token for dashboard read access
# - Leave blank only if the read proxy is intentionally disconnected
# - Local live-limited: required, secret, and must differ from CONTROL_TOKEN
# - If unset, the dashboard proxy falls back to CONTROL_TOKEN for read-only requests
OPERATOR_READ_TOKEN=

################################################################################
# DASHBOARD SERVER AUTH (dashboard service only)
################################################################################

# DASHBOARD_SESSION_SECRET: Required to sign operator sessions.
# Leave unset only if the dashboard should remain unconfigured and read-only.
# For local mutation-capable setup, generate this value before enabling login.
# The generated secret is dev-only and should not be committed.
DASHBOARD_SESSION_SECRET=

# DASHBOARD_OPERATOR_DIRECTORY_JSON: JSON array of operator directory entries.
# Each entry must include username, displayName, role, passwordSalt, and passwordHash.
# Optional fields: active (defaults true), passwordIterations (defaults 120000).
# For local mutation-capable setup, generate this value before enabling login.
# Use role "operator" for the smallest reversible local mutation test.
# Example:
# [
#   {
#     "username": "alice",
#     "displayName": "Alice Example",
#     "role": "operator",
#     "active": true,
#     "passwordSalt": "generated-salt",
#     "passwordHash": "generated-hash"
#   }
# ]
DASHBOARD_OPERATOR_DIRECTORY_JSON=
