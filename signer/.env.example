################################################################################
# BobbyExecute Remote Signer Environment
################################################################################

# NODE_ENV: development | test | production
NODE_ENV=development

# SIGNER_AUTH_TOKEN: Shared bearer token used by the bot/runtime to call this signer.
# Keep this secret isolated to the signer service and the bot/runtime service only.
# - Local live-limited: required and secret
SIGNER_AUTH_TOKEN=

# SIGNER_WALLET_PRIVATE_KEY: Solana signing secret for the wallet this signer controls.
# Accepted formats:
# - base58-encoded 64-byte secret key
# - JSON array secret key exported by Solana tooling
# - Local live-limited: required and secret
SIGNER_WALLET_PRIVATE_KEY=

# SIGNER_WALLET_ADDRESS: Public wallet address for the signing key.
# - Local live-limited: required and must match SIGNER_WALLET_PRIVATE_KEY
SIGNER_WALLET_ADDRESS=

# SIGNER_PORT: HTTP listen port
# - Local live-limited default: 8787
SIGNER_PORT=8787

# SIGNER_HOST: Optional bind address
# - Local live-limited default: 127.0.0.1
SIGNER_HOST=127.0.0.1

# SIGNER_KEY_ID: Optional key identifier to echo in responses and validate on requests.
SIGNER_KEY_ID=
