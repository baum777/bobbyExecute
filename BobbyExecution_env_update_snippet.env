################################################################################
# BOBBYEXECUTION ENV UPDATE SNIPPET
# Add these entries to your .env.example / .env template.
# Set them in Render service env vars for paper/live usage, or in local .env for
# private testing. Dry/stub paths do not require them, but the real Moralis and
# Jupiter adapter calls now fail closed when the keys are missing.
################################################################################

################################################################################
# DATA ADAPTER AUTH KEYS
################################################################################

# MORALIS_API_KEY: Moralis Solana/Data API auth key.
# Used by bot/src/adapters/moralis/client.ts.
# Typical request header: X-Api-Key: <api-key>
MORALIS_API_KEY=

# JUPITER_API_KEY: Jupiter quote/swap auth key.
# Used by bot/src/adapters/dex-execution/quotes.ts and swap.ts.
# Typical request header: x-api-key: <api-key>
JUPITER_API_KEY=

################################################################################
# DATA ADAPTERS
################################################################################

DEXPAPRIKA_BASE_URL=https://api.dexpaprika.com
MORALIS_BASE_URL=https://solana-gateway.moralis.io
JUPITER_QUOTE_URL=https://api.jup.ag/swap/v1
JUPITER_SWAP_URL=https://api.jup.ag/swap/v1
