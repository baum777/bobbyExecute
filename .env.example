################################################################################
# BobbyExecution Environment Configuration
# Copy to .env and fill in values for your environment
################################################################################

# NODE_ENV (development | test | production)
NODE_ENV=development

# RUNTIME_CONFIG_ENV: runtime/deployment label used by bot, control, and rehearsal flows
RUNTIME_CONFIG_ENV=development

################################################################################
# EXECUTION MODE - Safety & Trading Control
################################################################################

# LIVE_TRADING: Enable live trading mode (executionMode=live)
# - Safe boot / paper: false
# - Local live-limited: true
# - live-limited requires RPC_MODE=real, DRY_RUN=false, and the signer / Jupiter / control prerequisites below
LIVE_TRADING=false

# DRY_RUN: Force dry-run mode (no swaps executed)
# - Safe boot: true
# - Paper mode: false
# - Local live-limited: false
# - must not be true when LIVE_TRADING=true
DRY_RUN=true

# TRADING_ENABLED: Feature flag for trading module
# - Safe boot / paper: false
# - Local live-limited: true
TRADING_ENABLED=false

################################################################################
# RPC & BLOCKCHAIN
################################################################################

# RPC_MODE: Which RPC provider to use (stub | real)
# - Safe boot / paper: stub
# - Local live-limited: real
# - LIVE_TRADING=true requires RPC_MODE=real (fail-closed)
RPC_MODE=stub

# RPC_URL: Solana RPC endpoint
# - Safe boot / paper: can remain the default stub-friendly placeholder
# - Local live-limited: required and must point at a real Solana RPC endpoint
# - Helius (recommended): https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# - Alchemy: https://solana-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_URL=https://api.mainnet-beta.solana.com

################################################################################
# MARKET DATA PROVIDERS
################################################################################

# DISCOVERY_PROVIDER: token discovery source
# - dexscreener: default discovery adapter
# - moralis: explicitly disabled fallback only
DISCOVERY_PROVIDER=dexscreener

# MARKET_DATA_PROVIDER: runtime-facing market data source
# - dexpaprika: default normalized market adapter
# - dexscreener: discovery-oriented fallback only
# - moralis: explicitly disabled fallback only
MARKET_DATA_PROVIDER=dexpaprika

# STREAMING_PROVIDER: optional low-latency market stream source
# - dexpaprika: default stream adapter
# - off: disable streaming
STREAMING_PROVIDER=dexpaprika

# MORALIS_ENABLED: keep Moralis disabled unless explicitly re-enabled for fallback work
# - Safe boot / paper / local live-limited: false
MORALIS_ENABLED=false

################################################################################
# STAGE 3: LIVE-TEST MODE (Wave 8)
################################################################################

# LIVE_TEST_MODE: Enable limited capital live-test mode
# - Safe boot / paper: false
# - Local live-limited: true
LIVE_TEST_MODE=false

# RUNTIME_POLICY_AUTHORITY: config source for runtime behavior (ts-env | yaml)
RUNTIME_POLICY_AUTHORITY=ts-env

# ROLLOUT_POSTURE: allowed values are paper_only | micro_live | staged_live_candidate | paused_or_rolled_back
# - Safe boot / paper: paper_only
# - Local live-limited: micro_live
ROLLOUT_POSTURE=paper_only

# LIVE_TEST_MAX_CAPITAL_USD: Max capital per trade in live-test mode (Default: 100)
LIVE_TEST_MAX_CAPITAL_USD=100

# LIVE_TEST_MAX_TRADES_PER_DAY: Max trades per day in live-test mode (Default: 1)
LIVE_TEST_MAX_TRADES_PER_DAY=1

# LIVE_TEST_MAX_DAILY_LOSS_USD: Max daily loss in live-test mode (Default: 50)
LIVE_TEST_MAX_DAILY_LOSS_USD=50

################################################################################
# LEGACY DASHBOARD (dor-bot)
################################################################################

# BOT_KPI_URL: URL of the TypeScript bot API for the legacy dashboard bridge
BOT_KPI_URL=http://127.0.0.1:3333

# REPLAY_MODE: Deterministic trace IDs (testing/debugging)
REPLAY_MODE=false

################################################################################
# CONTROL / DASHBOARD / WORKER COORDINATION
################################################################################

# CONTROL_SERVICE_URL: Explicit control-service base URL; host/port fallback is also supported.
CONTROL_SERVICE_URL=http://127.0.0.1:3334

# CONTROL_SERVICE_HOSTNAME: Internal hostname for the control service fallback.
CONTROL_SERVICE_HOSTNAME=127.0.0.1

# CONTROL_SERVICE_PORT: Internal port for the control service fallback.
CONTROL_SERVICE_PORT=3334

# DASHBOARD_ORIGIN: Public dashboard origin used by bot/control flows.
DASHBOARD_ORIGIN=http://127.0.0.1:3000

# WORKER_SERVICE_NAME: Target worker service name for restart coordination.
WORKER_SERVICE_NAME=bobbyexecute-runtime-local

# WORKER_DEPLOY_HOOK_URL: Optional deploy hook used by restart coordination.
# Leave blank for local development.
WORKER_DEPLOY_HOOK_URL=

# WORKER_HEARTBEAT_INTERVAL_MS: Worker heartbeat cadence in milliseconds.
WORKER_HEARTBEAT_INTERVAL_MS=5000

# CONTROL_RESTARTS_ENABLED: Enable control-driven worker restarts.
CONTROL_RESTARTS_ENABLED=false

# CONTROL_RESTART_COOLDOWN_MS: Cooldown window between restart attempts.
CONTROL_RESTART_COOLDOWN_MS=300000

# CONTROL_RESTART_CONVERGENCE_TIMEOUT_MS: Maximum wait for restart convergence.
CONTROL_RESTART_CONVERGENCE_TIMEOUT_MS=600000

################################################################################
# WALLET & SECURITY
################################################################################

# WALLET_ADDRESS: Trading wallet Solana address
# - Safe boot / paper: blank
# - Local live-limited: required
# - Non-secret; format: base58 string
WALLET_ADDRESS=

# SIGNER_MODE: Signing boundary for live trading
# - disabled: No signer client is configured (paper/dry only)
# - remote: Use an external signer service (required for LIVE_TRADING=true)
# - Local live-limited: remote
SIGNER_MODE=disabled

# SIGNER_URL: HTTPS endpoint for the remote signer service
# - Safe boot / paper: blank
# - Local live-limited: required
# - Non-secret
SIGNER_URL=

# SIGNER_AUTH_TOKEN: Bearer token for server-to-server remote signing
# Do not reuse control-plane or dashboard secrets.
# - Safe boot / paper: blank
# - Local live-limited: required and secret
SIGNER_AUTH_TOKEN=

# SIGNER_KEY_ID: Optional signer key identifier for multi-key backends
SIGNER_KEY_ID=

# SIGNER_TIMEOUT_MS: Remote signer request timeout in milliseconds
SIGNER_TIMEOUT_MS=10000

# CONTROL_TOKEN: Required server-side auth token for mutating control routes
# Used by: POST /emergency-stop, /control/*
# - Safe boot / paper: blank
# - Local live-limited: required and secret
CONTROL_TOKEN=

# CONTROL_RESTART_ALERT_NOTIFICATION_COOLDOWN_MS: Rate-limit window for repeated restart alert notifications
CONTROL_RESTART_ALERT_NOTIFICATION_COOLDOWN_MS=300000

# NOTIFY_ROUTING_POLICY_MODE: default routing or explicit destination selection
NOTIFY_ROUTING_POLICY_MODE=default

# Destination 1: primary production escalation target
# Server-side only. Leave empty to disable the destination.
NOTIFY_WEBHOOK_PRIMARY_URL=
NOTIFY_WEBHOOK_PRIMARY_TOKEN=
NOTIFY_WEBHOOK_PRIMARY_HEADER=authorization
NOTIFY_WEBHOOK_PRIMARY_ENABLED=true
NOTIFY_PRIMARY_FORMAT=generic
NOTIFY_PRIMARY_COOLDOWN_MS=300000
NOTIFY_PRIMARY_RECOVERY_ENABLED=true
NOTIFY_PRIMARY_REPEATED_FAILURE_SUMMARY_ENABLED=false
NOTIFY_PRIMARY_ALLOW_WARNING=false
NOTIFY_PRIMARY_ENVIRONMENT_SCOPE=production
NOTIFY_PRIMARY_PRIORITY=10
NOTIFY_PRIMARY_TAGS=primary,production

# Destination 2: optional secondary escalation target
NOTIFY_WEBHOOK_SECONDARY_URL=
NOTIFY_WEBHOOK_SECONDARY_TOKEN=
NOTIFY_WEBHOOK_SECONDARY_HEADER=authorization
NOTIFY_WEBHOOK_SECONDARY_ENABLED=false
NOTIFY_SECONDARY_FORMAT=generic
NOTIFY_SECONDARY_COOLDOWN_MS=300000
NOTIFY_SECONDARY_RECOVERY_ENABLED=true
NOTIFY_SECONDARY_REPEATED_FAILURE_SUMMARY_ENABLED=true
NOTIFY_SECONDARY_ALLOW_WARNING=false
NOTIFY_SECONDARY_ENVIRONMENT_SCOPE=production
NOTIFY_SECONDARY_PRIORITY=20
NOTIFY_SECONDARY_TAGS=secondary,production

# Destination 3: optional staging-only escalation target
NOTIFY_WEBHOOK_STAGING_URL=
NOTIFY_WEBHOOK_STAGING_TOKEN=
NOTIFY_WEBHOOK_STAGING_HEADER=authorization
NOTIFY_WEBHOOK_STAGING_ENABLED=false
NOTIFY_STAGING_FORMAT=generic
NOTIFY_STAGING_COOLDOWN_MS=300000
NOTIFY_STAGING_RECOVERY_ENABLED=true
NOTIFY_STAGING_REPEATED_FAILURE_SUMMARY_ENABLED=false
NOTIFY_STAGING_ALLOW_WARNING=false
NOTIFY_STAGING_ENVIRONMENT_SCOPE=staging
NOTIFY_STAGING_PRIORITY=30
NOTIFY_STAGING_TAGS=staging

# Legacy compatibility fallback for older deployments
# CONTROL_RESTART_ALERT_WEBHOOK_URL remains supported as a primary destination fallback.
CONTROL_RESTART_ALERT_WEBHOOK_URL=
CONTROL_RESTART_ALERT_WEBHOOK_TOKEN=
CONTROL_RESTART_ALERT_WEBHOOK_HEADER=authorization
CONTROL_RESTART_ALERT_WEBHOOK_TIMEOUT_MS=5000
CONTROL_RESTART_ALERT_WEBHOOK_REQUIRED=true

# OPERATOR_READ_TOKEN: Reserved operator-read secret.
# Dashboard read-only control proxying can use this for GET/HEAD requests.
# - Safe boot / paper: blank
# - Local live-limited: required, secret, and must differ from CONTROL_TOKEN
OPERATOR_READ_TOKEN=

# LOG_LEVEL: Bot logging level (debug | info | warn | error)
LOG_LEVEL=info

################################################################################
# LLM / XAI / OPENAI (Persona, Fallback Cascade)
################################################################################
# Deployments: Set env vars per mode:
#   XAI:     XAI_API_KEY=sk-...  LAUNCH_MODE= (or xai)
#   OpenAI:  OPENAI_API_KEY=sk-...  LAUNCH_MODE=openai_fallback
#   Other:   OPENAI_API_KEY=...  OPENAI_BASE_URL=https://api.groq.com/openai/v1  LAUNCH_MODE=openai_fallback

# LAUNCH_MODE: Which LLM provider to use
# - xai (or unset with XAI_API_KEY): Prefer x.ai API
# - openai: Force OpenAI / OPENAI_BASE_URL even if XAI_API_KEY is set
# - openai_fallback: Use OpenAI (or OPENAI_BASE_URL) instead of XAI (legacy name)
LAUNCH_MODE=

# XAI_API_KEY: x.ai API key (when using XAI mode)
XAI_API_KEY=

# XAI_MODEL_PRIMARY: XAI model name (default: grok-beta)
XAI_MODEL_PRIMARY=grok-beta

# OPENAI_API_KEY: OpenAI API key (fallback / openai_fallback mode)
OPENAI_API_KEY=

# OPENAI_BASE_URL: Base URL for OpenAI-compatible API (e.g. groq, together)
# - Default: https://api.openai.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# OPENAI_MODEL: Model for OpenAI mode (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# LLM_SYSTEM_PROMPT: Optional override for system prompt
# LLM_CANNED_FALLBACK: Response when LLM fails (default: [Response unavailable])
# LLM_TEMPERATURE: 0–2 (default: 0.92)
# LLM_MAX_TOKENS: Max tokens per response (default: 280)

################################################################################
# DATA ADAPTERS
################################################################################

# DEXPAPRIKA_BASE_URL: DexPaprika market data API
DEXPAPRIKA_BASE_URL=https://api.dexpaprika.com

# MORALIS_BASE_URL: Moralis Solana wallet API base URL
MORALIS_BASE_URL=https://solana-gateway.moralis.io

# MORALIS_API_KEY: Moralis auth for adapter calls.
# - Safe boot / paper / local live-limited: blank while MORALIS_ENABLED=false
# - Live-mode startup fails closed if MORALIS_ENABLED=true and this is missing
MORALIS_API_KEY=

# JUPITER_QUOTE_URL: Jupiter swap API for quotes
JUPITER_QUOTE_URL=https://api.jup.ag/swap/v1

# JUPITER_API_KEY: Jupiter auth for quote/swap adapter calls.
# - Safe boot / paper: blank
# - Local live-limited: required and secret
# - Live-mode startup fails closed if this is missing
JUPITER_API_KEY=

# JUPITER_SWAP_URL: Jupiter swap API for execution
JUPITER_SWAP_URL=https://api.jup.ag/swap/v1

################################################################################
# STORAGE
################################################################################

# DATABASE_URL: Primary Postgres connection string.
# Leave blank for local in-memory storage.
DATABASE_URL=

# REDIS_URL: Redis connection string for runtime config/state.
# Leave blank for local in-memory storage.
REDIS_URL=

################################################################################
# CIRCUIT BREAKER & RESILIENCE
################################################################################

# CIRCUIT_BREAKER_FAILURE_THRESHOLD: Consecutive failures before breaker opens
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5

# CIRCUIT_BREAKER_RECOVERY_MS: Milliseconds before breaker retry
CIRCUIT_BREAKER_RECOVERY_MS=60000

################################################################################
# GOVERNANCE & RISK CONTROLS
################################################################################

# MAX_SLIPPAGE_PERCENT: Maximum allowed slippage for swaps (0-100)
MAX_SLIPPAGE_PERCENT=5

# REVIEW_POLICY_MODE: Approval flow for trades (none | draft_only | required)
# - none: No approval required
# - draft_only: Log decisions only
# - required: Approval required before execution
REVIEW_POLICY_MODE=required

################################################################################
# PERSISTENCE & OBSERVABILITY
################################################################################

# JOURNAL_PATH: Path to trade journal/audit log
JOURNAL_PATH=data/journal.jsonl

################################################################################
# REHEARSAL / RELEASE GATE
################################################################################

# REHEARSAL_EXECUTION_SOURCE: expected automated source for render rehearsals.
REHEARSAL_EXECUTION_SOURCE=automated

# REHEARSAL_ORCHESTRATION_MODE: expected orchestration mode for render rehearsals.
REHEARSAL_ORCHESTRATION_MODE=render_cron

# REHEARSAL_AUTOMATION_PROVIDER: expected automation provider for rehearsals.
REHEARSAL_AUTOMATION_PROVIDER=render

# REHEARSAL_SOURCE_KIND: expected source kind for rehearsal inputs.
REHEARSAL_SOURCE_KIND=canonical

# REHEARSAL_TARGET_KIND: expected target kind for rehearsal outputs.
REHEARSAL_TARGET_KIND=disposable

# REHEARSAL_SOURCE_CONTEXT: source-context label for rehearsal provenance.
REHEARSAL_SOURCE_CONTEXT=canonical-staging

# REHEARSAL_TARGET_CONTEXT: target-context label for rehearsal provenance.
REHEARSAL_TARGET_CONTEXT=disposable-rehearsal-staging

# REHEARSAL_RENDER_SERVICE_NAME: Render cron service name for DB rehearsal.
REHEARSAL_RENDER_SERVICE_NAME=bobbyexecute-rehearsal-refresh-staging

# REHEARSAL_CRON_SCHEDULE: expected cron schedule for the rehearsal job.
REHEARSAL_CRON_SCHEDULE=0 3 * * *

# REHEARSAL_MIGRATIONS_DIR: migrations directory used by rehearsal.
REHEARSAL_MIGRATIONS_DIR=migrations

# REHEARSAL_ACTOR_ID: operator/automation actor id for rehearsal records.
REHEARSAL_ACTOR_ID=render-rehearsal-refresh-staging

# REHEARSAL_ACTOR_DISPLAY_NAME: operator/automation display name for rehearsal records.
REHEARSAL_ACTOR_DISPLAY_NAME=Render rehearsal refresh

# REHEARSAL_SESSION_ID: session id used for rehearsal evidence.
REHEARSAL_SESSION_ID=render-cron-staging

# SOURCE_DATABASE_URL: source database URL for rehearsal/replay workflows.
SOURCE_DATABASE_URL=postgres://user:pass@host:5432/source_db

# TARGET_DATABASE_URL: target database URL for rehearsal/replay workflows.
TARGET_DATABASE_URL=postgres://user:pass@host:5432/target_db

################################################################################
# DASHBOARD & API
################################################################################

# PORT: HTTP server port (default: 3333)
PORT=3333

# HOST: HTTP server listen address (default: 0.0.0.0)
HOST=127.0.0.1

################################################################################
# DASHBOARD FRONTEND (dashboard/.env.local)
################################################################################

# NEXT_PUBLIC_API_URL: Bot API URL (must match PORT/HOST)
# - Local: http://localhost:3333
# - Production: https://your-api-server.com:3333
NEXT_PUBLIC_API_URL=http://127.0.0.1:3333

# NEXT_PUBLIC_USE_MOCK: Use mock data in dashboard (true | false)
# - true: Offline mock data (development)
# - false: Real API calls (production)
NEXT_PUBLIC_USE_MOCK=false

################################################################################
# DASHBOARD SERVER AUTH (dashboard service only)
################################################################################

# DASHBOARD_SESSION_SECRET: Required to sign dashboard operator sessions.
DASHBOARD_SESSION_SECRET=

# DASHBOARD_OPERATOR_DIRECTORY_JSON: JSON array of dashboard operators.
# Each entry must include username, displayName, role, passwordSalt, and passwordHash.
DASHBOARD_OPERATOR_DIRECTORY_JSON=

# Local Render CLI/tooling only. Never runtime auth and never in render.yaml.
RENDER_API_KEY=your_render_api_key_here
