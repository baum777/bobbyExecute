################################################################################
# BobbyExecution Environment Configuration
# Copy to .env and fill in values for your environment
################################################################################

# NODE_ENV (development | test | production)
NODE_ENV=development

################################################################################
# EXECUTION MODE - Safety & Trading Control
################################################################################

# LIVE_TRADING: Enable live trading mode (executionMode=live)
# - false: Dry-run mode (no actual swaps)
# - true: Live trading enabled (REQUIRES RPC_MODE=real)
LIVE_TRADING=false

# DRY_RUN: Force dry-run mode (no swaps executed)
# - true: Simulated trades only (override LIVE_TRADING=true)
# - false: Allow actual swaps (if LIVE_TRADING=true)
DRY_RUN=true

# TRADING_ENABLED: Feature flag for trading module
# - true: Trading enabled
# - false: Trading disabled at module level
TRADING_ENABLED=false

################################################################################
# RPC & BLOCKCHAIN
################################################################################

# RPC_MODE: Which RPC provider to use (stub | real)
# - stub: Deterministic fake data (development/testing only)
# - real: Live Solana RPC (mainnet)
# IMPORTANT: LIVE_TRADING=true requires RPC_MODE=real (fail-closed)
RPC_MODE=stub

# RPC_URL: Solana RPC endpoint
# - Default: https://api.mainnet-beta.solana.com
# - Helius (recommended): https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# - Alchemy: https://solana-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_URL=https://api.mainnet-beta.solana.com

################################################################################
# STAGE 3: LIVE-TEST MODE (Wave 8)
################################################################################

# LIVE_TEST_MODE: Enable limited capital live-test mode
# - true: Enable live-test constraints
# - false: Normal mode (Default)
LIVE_TEST_MODE=false

# LIVE_TEST_MAX_CAPITAL_USD: Max capital per trade in live-test mode (Default: 100)
LIVE_TEST_MAX_CAPITAL_USD=100

# LIVE_TEST_MAX_TRADES_PER_DAY: Max trades per day in live-test mode (Default: 1)
LIVE_TEST_MAX_TRADES_PER_DAY=1

# LIVE_TEST_MAX_DAILY_LOSS_USD: Max daily loss in live-test mode (Default: 50)
LIVE_TEST_MAX_DAILY_LOSS_USD=50

################################################################################
# LEGACY DASHBOARD (dor-bot)
################################################################################

# BOT_KPI_URL: URL of the TypeScript bot API for the legacy dashboard bridge
BOT_KPI_URL=http://localhost:3333

# REPLAY_MODE: Deterministic trace IDs (testing/debugging)
REPLAY_MODE=false

################################################################################
# WALLET & SECURITY
################################################################################

# WALLET_ADDRESS: Trading wallet Solana address
# Format: base58 string (44-44 characters)
WALLET_ADDRESS=

# CONTROL_TOKEN: Required server-side auth token for mutating control routes
# Used by: POST /emergency-stop, /control/*
CONTROL_TOKEN=

# CONTROL_RESTART_ALERT_NOTIFICATION_COOLDOWN_MS: Rate-limit window for repeated restart alert notifications
CONTROL_RESTART_ALERT_NOTIFICATION_COOLDOWN_MS=300000

# NOTIFY_ROUTING_POLICY_MODE: default routing or explicit destination selection
NOTIFY_ROUTING_POLICY_MODE=default

# Destination 1: primary production escalation target
# Server-side only. Leave empty to disable the destination.
NOTIFY_WEBHOOK_PRIMARY_URL=
NOTIFY_WEBHOOK_PRIMARY_TOKEN=
NOTIFY_WEBHOOK_PRIMARY_HEADER=authorization
NOTIFY_WEBHOOK_PRIMARY_ENABLED=true
NOTIFY_PRIMARY_FORMAT=generic
NOTIFY_PRIMARY_COOLDOWN_MS=300000
NOTIFY_PRIMARY_RECOVERY_ENABLED=true
NOTIFY_PRIMARY_REPEATED_FAILURE_SUMMARY_ENABLED=false
NOTIFY_PRIMARY_ALLOW_WARNING=false
NOTIFY_PRIMARY_ENVIRONMENT_SCOPE=production
NOTIFY_PRIMARY_PRIORITY=10
NOTIFY_PRIMARY_TAGS=primary,production

# Destination 2: optional secondary escalation target
NOTIFY_WEBHOOK_SECONDARY_URL=
NOTIFY_WEBHOOK_SECONDARY_TOKEN=
NOTIFY_WEBHOOK_SECONDARY_HEADER=authorization
NOTIFY_WEBHOOK_SECONDARY_ENABLED=false
NOTIFY_SECONDARY_FORMAT=generic
NOTIFY_SECONDARY_COOLDOWN_MS=300000
NOTIFY_SECONDARY_RECOVERY_ENABLED=true
NOTIFY_SECONDARY_REPEATED_FAILURE_SUMMARY_ENABLED=true
NOTIFY_SECONDARY_ALLOW_WARNING=false
NOTIFY_SECONDARY_ENVIRONMENT_SCOPE=production
NOTIFY_SECONDARY_PRIORITY=20
NOTIFY_SECONDARY_TAGS=secondary,production

# Destination 3: optional staging-only escalation target
NOTIFY_WEBHOOK_STAGING_URL=
NOTIFY_WEBHOOK_STAGING_TOKEN=
NOTIFY_WEBHOOK_STAGING_HEADER=authorization
NOTIFY_WEBHOOK_STAGING_ENABLED=false
NOTIFY_STAGING_FORMAT=generic
NOTIFY_STAGING_COOLDOWN_MS=300000
NOTIFY_STAGING_RECOVERY_ENABLED=true
NOTIFY_STAGING_REPEATED_FAILURE_SUMMARY_ENABLED=false
NOTIFY_STAGING_ALLOW_WARNING=false
NOTIFY_STAGING_ENVIRONMENT_SCOPE=staging
NOTIFY_STAGING_PRIORITY=30
NOTIFY_STAGING_TAGS=staging

# Legacy compatibility fallback for older deployments
# CONTROL_RESTART_ALERT_WEBHOOK_URL remains supported as a primary destination fallback.
CONTROL_RESTART_ALERT_WEBHOOK_URL=
CONTROL_RESTART_ALERT_WEBHOOK_TOKEN=
CONTROL_RESTART_ALERT_WEBHOOK_HEADER=authorization
CONTROL_RESTART_ALERT_WEBHOOK_TIMEOUT_MS=5000
CONTROL_RESTART_ALERT_WEBHOOK_REQUIRED=true

# OPERATOR_READ_TOKEN: Reserved operator-read secret.
# Current code does not use this as HTTP route auth; live-mode startup still requires it to stay distinct from CONTROL_TOKEN.
OPERATOR_READ_TOKEN=

# LOG_LEVEL: Bot logging level (debug | info | warn | error)
LOG_LEVEL=info

################################################################################
# LLM / XAI / OPENAI (Persona, Fallback Cascade)
################################################################################
# Deployments: Set env vars per mode:
#   XAI:     XAI_API_KEY=sk-...  LAUNCH_MODE= (or xai)
#   OpenAI:  OPENAI_API_KEY=sk-...  LAUNCH_MODE=openai_fallback
#   Other:   OPENAI_API_KEY=...  OPENAI_BASE_URL=https://api.groq.com/openai/v1  LAUNCH_MODE=openai_fallback

# LAUNCH_MODE: Which LLM provider to use
# - xai (or unset with XAI_API_KEY): Prefer x.ai API
# - openai: Force OpenAI / OPENAI_BASE_URL even if XAI_API_KEY is set
# - openai_fallback: Use OpenAI (or OPENAI_BASE_URL) instead of XAI (legacy name)
LAUNCH_MODE=

# XAI_API_KEY: x.ai API key (when using XAI mode)
XAI_API_KEY=

# XAI_MODEL_PRIMARY: XAI model name (default: grok-beta)
XAI_MODEL_PRIMARY=grok-beta

# OPENAI_API_KEY: OpenAI API key (fallback / openai_fallback mode)
OPENAI_API_KEY=

# OPENAI_BASE_URL: Base URL for OpenAI-compatible API (e.g. groq, together)
# - Default: https://api.openai.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# OPENAI_MODEL: Model for OpenAI mode (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# LLM_SYSTEM_PROMPT: Optional override for system prompt
# LLM_CANNED_FALLBACK: Response when LLM fails (default: [Response unavailable])
# LLM_TEMPERATURE: 0–2 (default: 0.92)
# LLM_MAX_TOKENS: Max tokens per response (default: 280)

################################################################################
# DATA ADAPTERS
################################################################################

# DEXPAPRIKA_BASE_URL: DexPaprika market data API
DEXPAPRIKA_BASE_URL=https://api.dexpaprika.com

# MORALIS_BASE_URL: Moralis Solana gateway
MORALIS_BASE_URL=https://solana-gateway.moralis.io

# MORALIS_API_KEY: Moralis auth for adapter calls. Live-mode startup fails closed if this is missing.
MORALIS_API_KEY=

# JUPITER_QUOTE_URL: Jupiter swap API for quotes
JUPITER_QUOTE_URL=https://api.jup.ag/swap/v1

# JUPITER_API_KEY: Jupiter auth for quote/swap adapter calls. Live-mode startup fails closed if this is missing.
JUPITER_API_KEY=

# JUPITER_SWAP_URL: Jupiter swap API for execution
JUPITER_SWAP_URL=https://api.jup.ag/swap/v1

################################################################################
# CIRCUIT BREAKER & RESILIENCE
################################################################################

# CIRCUIT_BREAKER_FAILURE_THRESHOLD: Consecutive failures before breaker opens
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5

# CIRCUIT_BREAKER_RECOVERY_MS: Milliseconds before breaker retry
CIRCUIT_BREAKER_RECOVERY_MS=60000

################################################################################
# GOVERNANCE & RISK CONTROLS
################################################################################

# MAX_SLIPPAGE_PERCENT: Maximum allowed slippage for swaps (0-100)
MAX_SLIPPAGE_PERCENT=5

# REVIEW_POLICY_MODE: Approval flow for trades (none | draft_only | required)
# - none: No approval required
# - draft_only: Log decisions only
# - required: Approval required before execution
REVIEW_POLICY_MODE=required

################################################################################
# PERSISTENCE & OBSERVABILITY
################################################################################

# JOURNAL_PATH: Path to trade journal/audit log
JOURNAL_PATH=data/journal.jsonl

################################################################################
# DASHBOARD & API
################################################################################

# PORT: HTTP server port (default: 3333)
PORT=3333

# HOST: HTTP server listen address (default: 0.0.0.0)
HOST=0.0.0.0

################################################################################
# DASHBOARD FRONTEND (dashboard/.env.local)
################################################################################

# NEXT_PUBLIC_API_URL: Bot API URL (must match PORT/HOST)
# - Local: http://localhost:3333
# - Production: https://your-api-server.com:3333
NEXT_PUBLIC_API_URL=http://localhost:3333

# NEXT_PUBLIC_USE_MOCK: Use mock data in dashboard (true | false)
# - true: Offline mock data (development)
# - false: Real API calls (production)
NEXT_PUBLIC_USE_MOCK=true

# NEXT_PUBLIC_ENV: Environment label for dashboard
# - STUB: Stub/mock mode
# - LIVE: Live trading mode
NEXT_PUBLIC_ENV=STUB

################################################################################
# DASHBOARD SERVER AUTH (dashboard service only)
################################################################################

# DASHBOARD_SESSION_SECRET: Required to sign dashboard operator sessions.
DASHBOARD_SESSION_SECRET=

# DASHBOARD_OPERATOR_DIRECTORY_JSON: JSON array of dashboard operators.
# Each entry must include username, displayName, role, passwordSalt, and passwordHash.
DASHBOARD_OPERATOR_DIRECTORY_JSON=

# Local-only Render API / CLI tooling auth. Never runtime auth and never in render.yaml.
RENDER_API_KEY=
