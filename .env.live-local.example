################################################################################
# BobbyExecute Local Live-Limited Environment
################################################################################
#
# Copy to .env.local or .env.live-local and fill in real values only.
# Blank shared-state values are not acceptable for a truthful multi-process run.
################################################################################

NODE_ENV=development
RUNTIME_CONFIG_ENV=development

################################################################################
# EXECUTION FLAGS
################################################################################

LIVE_TRADING=true
DRY_RUN=false
TRADING_ENABLED=true
LIVE_TEST_MODE=true
ROLLOUT_POSTURE=micro_live
RUNTIME_POLICY_AUTHORITY=ts-env
REVIEW_POLICY_MODE=required

################################################################################
# PROVIDERS
################################################################################

DISCOVERY_PROVIDER=dexscreener
MARKET_DATA_PROVIDER=dexpaprika
STREAMING_PROVIDER=dexpaprika
MORALIS_ENABLED=false

################################################################################
# RPC
################################################################################

RPC_MODE=real
RPC_URL=<real-solana-rpc-url>

################################################################################
# SIGNER
################################################################################

SIGNER_MODE=remote
SIGNER_URL=http://127.0.0.1:8787/sign
SIGNER_HOST=127.0.0.1
SIGNER_PORT=8787
SIGNER_AUTH_TOKEN=<shared-signer-token>
SIGNER_KEY_ID=local-key-1
SIGNER_TIMEOUT_MS=10000

################################################################################
# WALLET
################################################################################

WALLET_ADDRESS=<matching-public-wallet>

################################################################################
# CONTROL / OPERATOR TOKENS
################################################################################

# Generate these locally. They must be different values.
CONTROL_TOKEN=<generated-token-1>
OPERATOR_READ_TOKEN=<generated-token-2>

################################################################################
# CONTROL / DASHBOARD / WORKER COORDINATION
################################################################################

CONTROL_SERVICE_URL=http://127.0.0.1:3334
CONTROL_SERVICE_HOSTNAME=127.0.0.1
CONTROL_SERVICE_PORT=3334
DASHBOARD_ORIGIN=http://127.0.0.1:3000
WORKER_SERVICE_NAME=bobbyexecute-runtime-local
WORKER_DEPLOY_HOOK_URL=
WORKER_HEARTBEAT_INTERVAL_MS=5000
CONTROL_RESTARTS_ENABLED=false
CONTROL_RESTART_COOLDOWN_MS=300000
CONTROL_RESTART_CONVERGENCE_TIMEOUT_MS=600000

################################################################################
# MAIN LLM / OPENROUTER
################################################################################

# Compatibility/profile label retained from the repo examples.
# The runtime gate is the OPENAI_* block below.
LAUNCH_MODE=openai
OPENAI_API_KEY=<openrouter-api-key>
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Keep this aligned with the actual model you intend to run.
OPENAI_MODEL=qwen/qwen3.6-plus:free

OPENROUTER_HTTP_REFERER=http://127.0.0.1
OPENROUTER_X_TITLE=BobbyExecute
LLM_SYSTEM_PROMPT=
LLM_CANNED_FALLBACK=[Response unavailable]
LLM_TEMPERATURE=0.92
LLM_MAX_TOKENS=280

################################################################################
# ADVISORY LLM
################################################################################

ADVISORY_LLM_ENABLED=false
ADVISORY_LLM_PROVIDER=openai
# OpenAI advisory mode reuses the OPENAI_* settings above.
# This repo does not define a separate ADVISORY_LLM_MODEL env key.
ADVISORY_LLM_TIMEOUT_MS=1200
ADVISORY_LLM_MAX_TOKENS=512

################################################################################
# OPTIONAL QWEN REFERENCE
################################################################################

QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_MODEL=qwen/qwen3.6-plus:free

################################################################################
# DATA ADAPTERS
################################################################################

DEXPAPRIKA_BASE_URL=https://api.dexpaprika.com
MORALIS_BASE_URL=https://solana-gateway.moralis.io
MORALIS_API_KEY=
JUPITER_QUOTE_URL=https://api.jup.ag/swap/v1
JUPITER_API_KEY=<required>
JUPITER_SWAP_URL=https://api.jup.ag/swap/v1

################################################################################
# STORAGE / JOURNALING
################################################################################

JOURNAL_PATH=data/journal.jsonl
# Required for truthful multi-process local runs.
DATABASE_URL=<shared-postgres-url>
REDIS_URL=<shared-redis-url>

################################################################################
# CIRCUIT BREAKER / RISK
################################################################################

CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_MS=60000
MAX_SLIPPAGE_PERCENT=5

################################################################################
# LIVE TEST LIMITS
################################################################################

LIVE_TEST_MAX_CAPITAL_USD=100
LIVE_TEST_MAX_TRADES_PER_DAY=1
LIVE_TEST_MAX_DAILY_LOSS_USD=50

################################################################################
# DASHBOARD / API
################################################################################

PORT=3333
HOST=127.0.0.1
BOT_KPI_URL=http://127.0.0.1:3333
REPLAY_MODE=false
LOG_LEVEL=info

################################################################################
# DASHBOARD FRONTEND
################################################################################

NEXT_PUBLIC_API_URL=http://127.0.0.1:3333
NEXT_PUBLIC_USE_MOCK=false

################################################################################
# DASHBOARD SERVER AUTH
################################################################################

DASHBOARD_SESSION_SECRET=
DASHBOARD_OPERATOR_DIRECTORY_JSON=
