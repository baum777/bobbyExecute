{
  "name": "@onchain-trading-bot/core",
  "version": "0.1.0",
  "description": "Production-grade Onchain Trading Bot - OrchestrAI patterns",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./advisory-llm": {
      "types": "./dist/advisory-llm/index.d.ts",
      "import": "./dist/advisory-llm/index.js"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:golden": "vitest run tests/golden-tasks tests/harness",
    "lint": "tsc --noEmit",
    "openapi:validate": "npx @apidevtools/swagger-cli validate openapi.yaml",
    "test:chaos": "vitest run tests/chaos",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:config": "vitest run tests/config",
    "db:status": "node dist/scripts/db-status.js",
    "db:migrate": "node dist/scripts/db-migrate.js",
    "recovery:db-backup": "node dist/scripts/control-backup.js",
    "recovery:db-restore": "node dist/scripts/control-restore.js",
    "recovery:db-validate": "node dist/scripts/control-restore-validate.js",
    "recovery:db-rehearse": "node dist/scripts/db-rehearse.js",
    "recovery:db-rehearse:render": "node dist/scripts/render-db-rehearse.js",
    "recovery:worker-state": "node dist/scripts/worker-state-drill.js",
    "premerge": "npm run lint && npm test",
    "live:preflight": "npm run premerge && npm run build && node dist/scripts/live-test-preflight.js",
    "live:test": "npm run live:preflight && node dist/server/run.js",
    "start:server": "node dist/server/run.js",
    "start:control": "node dist/control/run.js",
    "start:worker": "node dist/worker/run.js",
    "validate:openapi": "swagger-cli validate openapi.yaml"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.0",
    "fastify": "^5.1.0",
    "openai": "^4.73.0",
    "pg": "^8.20.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "redis": "^5.11.0",
    "snappyjs": "^0.7.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/snappyjs": "^0.7.1",
    "typescript": "~5.6.0",
    "vitest": "^2.1.0"
  }
}
