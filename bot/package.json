{
  "name": "@onchain-trading-bot/core",
  "version": "0.1.0",
  "description": "Production-grade Onchain Trading Bot - OrchestrAI patterns",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:golden": "vitest run tests/golden-tasks tests/harness",
    "lint": "tsc --noEmit",
    "openapi:validate": "npx @apidevtools/swagger-cli validate openapi.yaml",
    "test:chaos": "vitest run tests/chaos",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:config": "vitest run tests/config",
    "premerge": "npm run lint && npm run test:golden && npm run test:chaos && npm run test:integration && npm run test:e2e && npm run test:config",
    "start:server": "node dist/server/run.js",
    "validate:openapi": "swagger-cli validate docs/architecture/openapi.yaml"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.0",
    "fastify": "^5.1.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "snappyjs": "^0.7.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/snappyjs": "^0.7.1",
    "typescript": "~5.6.0",
    "vitest": "^2.1.0"
  }
}
