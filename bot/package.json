{
  "name": "@onchain-trading-bot/core",
  "version": "0.1.0",
  "description": "Production-grade Onchain Trading Bot - OrchestrAI patterns",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:golden": "vitest run tests/golden-tasks tests/harness",
    "lint": "tsc --noEmit",
    "test:chaos": "vitest run tests/chaos",
    "premerge": "npm run lint && npm run test:golden && npm run test:chaos"
  },
  "dependencies": {
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "snappyjs": "^0.7.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/snappyjs": "^0.7.1",
    "typescript": "~5.6.0",
    "vitest": "^2.1.0"
  }
}
