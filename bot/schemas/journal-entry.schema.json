{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "journal-entry.schema.json",
  "type": "object",
  "required": ["traceId", "timestamp", "stage", "input", "output", "eventHash"],
  "properties": {
    "traceId": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "stage": { "type": "string" },
    "decisionHash": { "type": "string" },
    "resultHash": { "type": "string" },
    "input": {},
    "output": {},
    "blocked": { "type": "boolean" },
    "reason": { "type": "string" },
    "eventHash": { "type": "string" },
    "prevEventHash": { "type": "string" }
  },
  "additionalProperties": false
}
